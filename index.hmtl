<!-- QR -->

<div class="ov" id="qrModal">
  <div class="modal" style="max-width:380px">
    <div class="mh"><div class="mt">📱 Veli QR Kayıt</div><button class="mc" onclick="closeModal('qrModal')">✕</button></div>
    <div class="mb" style="text-align:center">
      <div style="font-size:12px;color:var(--muted);margin-bottom:13px">Veliler bu kodu okutunca kayıt formu açılır</div>
      <div class="qr-box" id="qrDiv"></div>
      <div style="display:flex;align-items:center;gap:8px;background:var(--glass);border:1px solid var(--rim);border-radius:var(--r-sm);padding:9px 13px;margin-top:12px">
        <span style="flex:1;font-family:'Space Mono',monospace;font-size:10px;color:var(--cyan);overflow:hidden;text-overflow:ellipsis;white-space:nowrap" id="qrUrlTxt"></span>
        <button class="btn btn-ghost btn-sm" onclick="copyQr()">📋</button>
      </div>
      <button class="btn btn-amber btn-block" style="margin-top:10px" onclick="window.print()">🖨️ Yazdır</button>
    </div>
  </div>
</div>

<!-- Veli Form -->

<div class="ov" id="veliModal">
  <div class="modal" style="max-width:540px">
    <div class="mh"><div class="mt">🧾 Veli Kayıt Formu</div><button class="mc" onclick="closeModal('veliModal')">✕</button></div>
    <div class="mb" id="veliBody"></div>
  </div>
</div>

<div id="tc"></div>

<script>
// ============================================================
// CONSTANTS
// ============================================================
const GS=17;
const GC=['#f59e0b','#3b82f6','#10b981','#8b5cf6','#ef4444','#06b6d4','#ec4899','#f97316','#6366f1','#84cc16','#a855f7','#14b8a6'];
const ACCS_KEY='sa_accs';
const MAX_PROJ=5;
const DEV_PHONE='905533498766';
const DEV_PWD='SERVIS2025DEV#MSTR';
const LK='sa_lic';
const AK='sa_act';
const DK='sa_dev';
const ONE_YEAR=365*24*60*60*1000;

// ============================================================
// GLOBALS
// ============================================================
let curUser=null,curProj=null,currentTab=null;
let pickColor_sel='#f59e0b';
let selRole_val='admin';
let voiceOn=false,curSpeech=null,helpOpen=false;
let curFiyatId=null,stopTimers={},traffic='low';
let simInt=null,gpsWatch=null,myLat=null,myLng=null;
let adminMap=null,drvMap=null,adminMarkers={},schoolMark=null,selfMark=null;
let P={},veliData={},veliStep=1;

// ============================================================
// STORAGE
// ============================================================
const SK=id=>'sa_p_'+id;
const BK=id=>'sa_b_'+id;
function getAccs(){try{return JSON.parse(localStorage.getItem(ACCS_KEY)||'[]');}catch{return[];}}
function saveAccs(a){localStorage.setItem(ACCS_KEY,JSON.stringify(a));}
function getPD(id){try{return JSON.parse(localStorage.getItem(SK(id))||'null')||initPD();}catch{return initPD();}}
function savePD(id,d){localStorage.setItem(SK(id),JSON.stringify(d));}
function getBas(pid){try{return JSON.parse(localStorage.getItem(BK(pid))||'[]');}catch{return[];}}
function saveBas(pid,l){localStorage.setItem(BK(pid),JSON.stringify(l));}
function initPD(){return{students:[],stops:[],drivers:[],groupAssignments:{},driverStatus:{},schoolLat:null,schoolLng:null};}
function saveCP(){if(curProj&&P[curProj.id])savePD(curProj.id,P[curProj.id]);}
function D(){return P[curProj?.id]||initPD();}

// ============================================================
// LICENSE SYSTEM
// ============================================================
function getLics(){try{return JSON.parse(localStorage.getItem(LK)||'[]');}catch{return[];}}
function saveLics(l){localStorage.setItem(LK,JSON.stringify(l));}
function getAct(){try{return JSON.parse(localStorage.getItem(AK)||'null');}catch{return null;}}
function saveAct(a){localStorage.setItem(AK,JSON.stringify(a));}
function isDevM(){return localStorage.getItem(DK)==='1';}
function devId(){let i=localStorage.getItem('sa_did');if(!i){i=Math.random().toString(36).slice(2)+Date.now().toString(36);localStorage.setItem('sa_did',i);}return i;}
function genCode(){const c='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';const s=()=>Array.from({length:4},()=>c[Math.floor(Math.random()*c.length)]).join('');return s()+'-'+s()+'-'+s();}
function fmtDate(ms){return new Date(ms).toLocaleDateString('tr-TR',{day:'2-digit',month:'2-digit',year:'numeric'});}

function checkLicense(){
  if(isDevM()){showLic('dev');return false;}
  const a=getAct();
  if(a){
    if(a.expiresAt&&Date.now()>a.expiresAt){
      localStorage.removeItem(AK);
      showLic('activate');
      setTimeout(()=>{setLicMsg('Lisans suresi doldu. WhatsApp ile yeni kod isteyin.','err');},200);
      return false;
    }
    const lics=getLics();
    const l=lics.find(x=>x.code===a.code);
    if(l&&l.status==='expired'){localStorage.removeItem(AK);showLic('activate');return false;}
    return true;
  }
  showLic('activate');
  return false;
}

function showLic(mode){
  document.getElementById('licScreen').classList.add('show');
  if(mode==='activate') renderLicActivate();
  else renderLicDev();
}
function hideLic(){document.getElementById('licScreen').classList.remove('show');}

function setLicMsg(txt,cls){
  const el=document.getElementById('licMsg');
  if(el){el.textContent=txt;el.className='lic-msg show '+cls;}
}

function renderLicActivate(){
  document.getElementById('licCard').innerHTML=`
    <div class="lic-logo">
      <div class="lic-icon">🚌</div>
      <div class="lic-title-txt">Servis Asistanı</div>
      <div class="lic-sub-txt">Kullanmak icin 1 yillik lisans kodu gereklidir.<br>Asagidan WhatsApp ile kod isteyebilirsiniz.</div>
    </div>
    <button class="btn btn-wa btn-block btn-lg" onclick="reqWA()" style="margin-bottom:14px">
      💬 WhatsApp ile Kod Iste
    </button>
    <div class="sep-row"><span style="font-size:11px;color:var(--muted)">Kodunuz varsa girin</span></div>
    <input class="code-input" id="licInput" placeholder="XXXX-XXXX-XXXX" maxlength="14"
      oninput="fmtCode(this)" onkeydown="if(event.key==='Enter')doActivate()">
    <div class="lic-msg" id="licMsg"></div>
    <button class="btn btn-amber btn-block btn-lg" onclick="doActivate()">Kodu Onayla — Baslat</button>
    <div style="text-align:center;margin-top:18px;padding-top:14px;border-top:1px solid var(--rim)">
      <button onclick="promptDev()" style="background:none;border:none;color:var(--muted);font-size:11px;cursor:pointer;font-family:inherit">Gelistirici Girisi</button>
    </div>`;
}

function reqWA(){
  const msg='Servis Asistani - Lisans Talebi\n\nMerhaba, uygulamanizi kullanmak istiyorum.\n\nCihaz ID: '+devId()+'\nTarih: '+new Date().toLocaleString('tr-TR')+'\n\nLutfen 1 yillik aktivasyon kodumu gonder misiniz?';
  window.open('https://wa.me/'+DEV_PHONE+'?text='+encodeURIComponent(msg),'_blank');
  setLicMsg('WhatsApp acildi! Mesaj gonderdikten sonra kodu buraya girin.','ok');
}

function fmtCode(el){
  let v=el.value.replace(/[^A-Z0-9]/gi,'').toUpperCase();
  if(v.length>4)v=v.slice(0,4)+'-'+v.slice(4);
  if(v.length>9)v=v.slice(0,9)+'-'+v.slice(9);
  el.value=v.slice(0,14);
  el.classList.remove('ok','bad');
  const m=document.getElementById('licMsg');
  if(m)m.className='lic-msg';
}

function doActivate(){
  const code=(document.getElementById('licInput')?.value||'').trim().toUpperCase();
  if(!code||code.length<14){setLicMsg('Kod formati hatali: XXXX-XXXX-XXXX','err');return;}
  const lics=getLics();
  const lic=lics.find(l=>l.code===code);
  if(!lic){document.getElementById('licInput').classList.add('bad');setLicMsg('Bu kod bulunamadi. Gelistirici ile iletisime gecin.','err');return;}
  if(lic.status==='used'||lic.status==='expired'){document.getElementById('licInput').classList.add('bad');setLicMsg('Bu kodun suresi dolmus veya kullanilmis.','err');return;}
  const now=Date.now();
  const exp=now+ONE_YEAR;
  lic.status='active';lic.activatedAt=now;lic.expiresAt=exp;lic.deviceId=devId();
  saveLics(lics);
  saveAct({code,kurum:lic.kurum,activatedAt:now,expiresAt:exp,deviceId:devId()});
  document.getElementById('licInput').classList.add('ok');
  setLicMsg('Aktivasyon basarili! 1 yillik lisans: '+fmtDate(exp)+' tarihine kadar gecerli.','ok');
  setTimeout(()=>{hideLic();checkAccount();},2000);
}

function renderLicDev(){
  const lics=getLics();
  const now=Date.now();
  const nAct=lics.filter(l=>l.status==='active'&&(!l.expiresAt||l.expiresAt>now)).length;
  const nPend=lics.filter(l=>l.status==='pending').length;
  const nExp=lics.length-nAct-nPend;
  const rows=lics.length===0
    ?'<div style="color:var(--muted);font-size:12px;padding:10px 0;text-align:center">Henuz lisans yok</div>'
    :lics.slice().reverse().map(l=>{
      const exp=l.expiresAt&&l.expiresAt<now;
      const cls=l.status==='active'&&!exp?'dr-active':l.status==='pending'?'dr-pending':'dr-expired';
      const lbl=l.status==='active'&&!exp?'Aktif':l.status==='pending'?'Bekliyor':'Bitti';
      const clr=l.status==='active'&&!exp?'var(--green2)':l.status==='pending'?'var(--amber2)':'var(--red2)';
      return '<div class="dev-row '+cls+'"><div style="flex:1;min-width:0"><div class="dev-code">'+l.code+'</div><div style="font-size:10px;color:var(--muted);margin-top:3px">'+(l.kurum||'Kurum yok')+' &bull; '+l.tarih+'</div>'+(l.activatedAt?'<div style="font-size:10px;color:var(--cyan)">Bitis: '+fmtDate(l.expiresAt)+'</div>':'')+'</div><div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0"><div style="font-size:11px;font-weight:700;color:'+clr+'">'+lbl+'</div><button onclick="sendCode(\''+l.code+'\')" class="btn btn-wa btn-sm">WA Gonder</button>'+(l.status!=='used'?'<button onclick="revokeCode(\''+l.code+'\')" class="btn btn-red btn-sm">Iptal</button>':'')+'</div></div>';
    }).join('');
  document.getElementById('licCard').innerHTML=`
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
      <div><div style="font-size:16px;font-weight:800">Gelistirici Paneli</div><div style="font-size:11px;color:var(--muted);margin-top:2px">Lisans Yonetimi</div></div>
      <button class="btn btn-ghost btn-sm" onclick="devLogout()">Cikis</button>
    </div>
    <div class="stat-row" style="margin-bottom:16px">
      <div class="stat-box"><div class="stat-num" style="color:var(--green2)">${nAct}</div><div class="stat-lbl">Aktif</div></div>
      <div class="stat-box"><div class="stat-num" style="color:var(--amber2)">${nPend}</div><div class="stat-lbl">Bekliyor</div></div>
      <div class="stat-box"><div class="stat-num" style="color:var(--muted)">${nExp}</div><div class="stat-lbl">Bitti</div></div>
    </div>
    <div style="margin-bottom:14px">
      <div class="label" style="margin-bottom:8px">Yeni Lisans Olustur (1 Yil)</div>
      <div style="display:flex;gap:8px">
        <input class="fi" id="newKurum" placeholder="Kurum / Okul adi" style="flex:1">
        <button class="btn btn-amber" onclick="createCode()">Uret</button>
      </div>
    </div>
    <div class="label" style="margin-bottom:8px">Tum Lisanslar (${lics.length})</div>
    <div class="dev-table">${rows}</div>
    <button class="btn btn-blue btn-block" style="margin-top:14px" onclick="hideLic();checkAccount()">Uygulamaya Gec</button>`;
}

function createCode(){
  const kurum=(document.getElementById('newKurum')?.value||'').trim();
  if(!kurum){toast('Kurum adi girin!','error');return;}
  const code=genCode();
  const lics=getLics();
  lics.push({code,kurum,status:'pending',tarih:new Date().toLocaleString('tr-TR'),activatedAt:null,expiresAt:null,deviceId:null});
  saveLics(lics);
  renderLicDev();
  sendCode(code);
}

function sendCode(code){
  const l=getLics().find(x=>x.code===code);
  const msg='Servis Asistani - Aktivasyon Kodu\n\nMerhaba'+(l?.kurum?' '+l.kurum:'')+'!\n\n1 yillik aktivasyon kodunuz:\n\n'+code+'\n\nUygulamayi acin, kodu girin ve baslayin!\n\nBitis tarihi: '+fmtDate(Date.now()+ONE_YEAR);
  window.open('https://wa.me/?text='+encodeURIComponent(msg),'_blank');
}

function revokeCode(code){
  if(!confirm('Bu lisansi iptal et?'))return;
  const lics=getLics();
  const l=lics.find(x=>x.code===code);
  if(l){l.status='expired';l.expiresAt=Date.now()-1;}
  saveLics(lics);
  const a=getAct();
  if(a?.code===code)localStorage.removeItem(AK);
  renderLicDev();
  toast('Lisans iptal edildi','warning');
}

function promptDev(){
  const pw=prompt('Sifre:');
  if(pw===DEV_PWD){localStorage.setItem(DK,'1');renderLicDev();}
  else if(pw!=null)toast('Yanlis sifre','error');
}
function devLogout(){localStorage.removeItem(DK);renderLicActivate();}

// ============================================================
// UTILS
// ============================================================
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2);}
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
function toast(msg,type,dur){
  type=type||'info';dur=dur||3500;
  const icons={success:`✅`,error:`❌`,info:`ℹ️`,warning:`⚠️`};
  const t=document.createElement('div');
  t.className='toast '+type;
  t.innerHTML='<span>'+icons[type]+'</span><span>'+msg+'</span>';
  document.getElementById('tc').appendChild(t);
  setTimeout(()=>t.remove(),dur);
}

