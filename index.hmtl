      <div id="fiyatInfo" style="background:var(--glass);border:1px solid var(--rim);border-radius:var(--r-md);padding:11px 14px;margin-bottom:14px;font-size:13px"></div>
      <div class="fg-row">
        <div class="fg"><label class="fl">Aylık Fiyat (₺) <span class="req">*</span></label><input class="fi" id="ft_f" type="number" placeholder="1500" oninput="updFiyat()"></div>
