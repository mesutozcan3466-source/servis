// VOICE
// ============================================================
const VT={
  proj:`Proje secim ekranındasınız. Her proje bir okul veya isletmenin servis sistemini temsil eder.`,
  admin_overview:`Genel bakis ekranındasınız. Aracların gercek konumunu haritada gorebilir, soforleri arayabilirsiniz.`,
  admin_bas:'Basvuru yonetimi. Velilerin gonderdigi formlar burada, fiyat belirleyin, onaylayin.',
  admin_groups:`Grup yonetimi. Ogrenciler km ye gore 17 li gruplara bolunur. Her gruba sofor atayın.`,
  admin_students:`Ogrenci listesi. Uzaktan yakina siralidir. Eklenince otomatik gruba atanir.`,
  admin_qr:`QR Kayit. Bu kodu yazdirip okul panosuna asin. Veliler form dolduruca basvuru gelir.`,
  driver_route:`Gurzergah ekranidasiniz. Sol taraftan grup secin, ogrenci bindi butonuna basin.`,
  driver_students:`Ogrencileriniz burada. Telefona tiklayarak arama yapabilirsiniz.`,
};
function toggleVoice(){
  voiceOn=!voiceOn;
  const btn=document.getElementById('voiceBtn');
  btn.textContent=voiceOn?`🔊`:`🔇`;
  btn.classList.toggle('speaking',voiceOn);
  if(voiceOn&&currentTab)speakTxt(VT[currentTab]||'');
  else stopSpeak();
}
function speakTxt(t){
  if(!('speechSynthesis' in window))return;
  stopSpeak();
  const u=new SpeechSynthesisUtterance(t);
  u.lang='tr-TR';u.rate=0.9;
  speechSynthesis.speak(u);
}
function stopSpeak(){if(speechSynthesis?.speaking)speechSynthesis.cancel();}
function speakCurrentHelp(){speakTxt(VT[currentTab]||VT.proj);}

