      <div class="fg-row">
        <div class="fg"><label class="fl">Öğrenci Tel</label><input class="fi" id="f_stutel" type="tel" placeholder="05XX..."></div>
        <div class="fg"><label class="fl">Veli Tel <span class="req">*</span></label><input class="fi" id="f_partel" type="tel" placeholder="05XX..."></div>
      </div>
      <div class="fg-row">
        <div class="fg"><label class="fl">Mesafe (km) <span class="req">*</span></label><input class="fi" id="f_km" type="number" step="0.1" value="0"></div>
        <div class="fg"><label class="fl">Veli Adı</label><input class="fi" id="f_parname" placeholder="Mehmet Yılmaz"></div>
      </div>
