<!DOCTYPE html>

<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="theme-color" content="#060d1a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="ServisApp">
<title>Servis Asistanı</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
/* ============================================
   DESIGN SYSTEM
   ============================================ */
:root {
  --ink:       #060d1a;
  --ink2:      #0d1829;
  --ink3:      #152238;
  --glass:     rgba(255,255,255,0.04);
  --glass2:    rgba(255,255,255,0.07);
  --rim:       rgba(255,255,255,0.09);
  --rim2:      rgba(255,255,255,0.14);
  --amber:     #f59e0b;
  --amber2:    #fbbf24;
  --amber-glow:rgba(245,158,11,0.25);
  --blue:      #3b82f6;
  --blue2:     #60a5fa;
  --cyan:      #06b6d4;
  --green:     #10b981;
  --green2:    #34d399;
  --red:       #ef4444;
  --red2:      #f87171;
  --muted:     rgba(255,255,255,0.38);
  --muted2:    rgba(255,255,255,0.18);
  --text:      #e8edf5;
  --text2:     rgba(232,237,245,0.75);
  --r-sm:      8px;
  --r-md:      12px;
  --r-lg:      18px;
  --r-xl:      24px;
  --shadow:    0 8px 32px rgba(0,0,0,0.45);
  --shadow-sm: 0 2px 12px rgba(0,0,0,0.35);
}

- { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

html, body {
height:100%; overflow:hidden;
font-family:‘Plus Jakarta Sans’,sans-serif;
background:var(–ink);
color:var(–text);
font-size:14px;
line-height:1.5;
}

/* BACKGROUND MESH */
body::before {
content:’’;
position:fixed; inset:0; z-index:0;
background:
radial-gradient(ellipse 80% 50% at 20% -10%, rgba(245,158,11,0.08) 0%, transparent 60%),
radial-gradient(ellipse 60% 40% at 80% 110%, rgba(59,130,246,0.07) 0%, transparent 55%),
radial-gradient(ellipse 100% 80% at 50% 50%, rgba(6,182,212,0.03) 0%, transparent 70%);
pointer-events:none;
}

/* ── SCROLL ── */
.scr { overflow-y:auto; overflow-x:hidden; -webkit-overflow-scrolling:touch; }
.scr::-webkit-scrollbar { width:3px; }
.scr::-webkit-scrollbar-thumb { background:var(–rim); border-radius:2px; }

/* ── TYPOGRAPHY ── */
.mono { font-family:‘Space Mono’,monospace; }
.label { font-size:10px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; color:var(–muted); }
.title-lg { font-size:22px; font-weight:800; }
.title-md { font-size:16px; font-weight:700; }
.title-sm { font-size:13px; font-weight:700; }

/* ── GLASS CARDS ── */
.card {
background:var(–glass);
border:1px solid var(–rim);
border-radius:var(–r-lg);
backdrop-filter:blur(12px);
-webkit-backdrop-filter:blur(12px);
}
.card-solid {
background:var(–ink2);
border:1px solid var(–rim);
border-radius:var(–r-lg);
}
.card-amber {
background:linear-gradient(135deg, rgba(245,158,11,0.12), rgba(251,191,36,0.06));
border:1px solid rgba(245,158,11,0.3);
border-radius:var(–r-lg);
}
.card-green {
background:linear-gradient(135deg, rgba(16,185,129,0.12), rgba(6,182,212,0.06));
border:1px solid rgba(16,185,129,0.3);
border-radius:var(–r-lg);
}
.card-blue {
background:linear-gradient(135deg, rgba(59,130,246,0.12), rgba(6,182,212,0.06));
border:1px solid rgba(59,130,246,0.3);
border-radius:var(–r-lg);
}

/* ── BUTTONS ── */
.btn {
display:inline-flex; align-items:center; gap:7px;
padding:9px 16px; border-radius:var(–r-sm);
font-family:‘Plus Jakarta Sans’,sans-serif;
font-size:13px; font-weight:700;
border:none; cursor:pointer;
transition:all 0.18s cubic-bezier(0.4,0,0.2,1);
white-space:nowrap; position:relative; overflow:hidden;
}
.btn::after {
content:’’; position:absolute; inset:0;
background:rgba(255,255,255,0);
transition:background 0.15s;
}
.btn:hover::after { background:rgba(255,255,255,0.06); }
.btn:active { transform:scale(0.97); }

.btn-amber {
background:linear-gradient(135deg, var(–amber), #d97706);
color:#000; box-shadow:0 4px 20px rgba(245,158,11,0.35);
}
.btn-amber:hover { box-shadow:0 6px 28px rgba(245,158,11,0.5); transform:translateY(-1px); }
.btn-blue {
background:linear-gradient(135deg, #3b82f6, #2563eb);
color:#fff; box-shadow:0 4px 20px rgba(59,130,246,0.3);
}
.btn-blue:hover { box-shadow:0 6px 28px rgba(59,130,246,0.45); transform:translateY(-1px); }
.btn-green {
background:linear-gradient(135deg, var(–green), #059669);
color:#fff; box-shadow:0 4px 20px rgba(16,185,129,0.3);
}
.btn-green:hover { box-shadow:0 6px 28px rgba(16,185,129,0.45); transform:translateY(-1px); }
.btn-red {
background:linear-gradient(135deg, var(–red), #dc2626);
color:#fff;
}
.btn-ghost {
background:var(–glass2); border:1px solid var(–rim);
color:var(–text);
}
.btn-ghost:hover { border-color:var(–rim2); }
.btn-wa {
background:linear-gradient(135deg, #25D366, #128C7E);
color:#fff; box-shadow:0 4px 20px rgba(37,211,102,0.3);
}
.btn-sm { padding:5px 11px; font-size:12px; border-radius:7px; }
.btn-lg { padding:14px 24px; font-size:15px; border-radius:var(–r-md); }
.btn-block { width:100%; justify-content:center; }

/* ── FORM ── */
.fg { margin-bottom:14px; }
.fg-row { display:flex; gap:10px; }
.fg-row .fg { flex:1; }
.fl {
display:block; margin-bottom:6px;
font-size:11px; font-weight:700;
letter-spacing:0.8px; text-transform:uppercase;
color:var(–muted);
}
.fl .req { color:var(–amber); }
.fi {
width:100%;
background:rgba(255,255,255,0.05);
border:1px solid var(–rim);
border-radius:var(–r-sm);
padding:11px 14px;
color:var(–text);
font-family:‘Plus Jakarta Sans’,sans-serif;
font-size:14px;
outline:none;
transition:border-color 0.2s, background 0.2s;
}
.fi:focus {
border-color:rgba(245,158,11,0.6);
background:rgba(245,158,11,0.04);
}
.fi::placeholder { color:var(–muted2); }
.fi.err { border-color:rgba(239,68,68,0.6); }

/* ── PILL / BADGE ── */
.pill {
display:inline-flex; align-items:center; gap:5px;
padding:3px 10px; border-radius:20px;
font-size:11px; font-weight:700;
border:1px solid;
}
.pill-amber { color:var(–amber); border-color:rgba(245,158,11,0.35); background:rgba(245,158,11,0.1); }
.pill-green { color:var(–green2); border-color:rgba(16,185,129,0.35); background:rgba(16,185,129,0.1); }
.pill-blue  { color:var(–blue2); border-color:rgba(59,130,246,0.35); background:rgba(59,130,246,0.1); }
.pill-red   { color:var(–red2); border-color:rgba(239,68,68,0.35); background:rgba(239,68,68,0.1); }
.pill-muted { color:var(–muted); border-color:var(–rim); background:var(–glass); }

/* ── PULSE DOTS ── */
.pulse { width:9px; height:9px; border-radius:50%; flex-shrink:0; }
.pulse-green { background:var(–green); animation:pulseAnim 2s infinite; }
.pulse-amber { background:var(–amber); animation:pulseAnim 2s infinite; }
.pulse-muted { background:rgba(255,255,255,0.25); }
@keyframes pulseAnim {
0%,100% { box-shadow:0 0 0 0 currentColor; opacity:1; }
50% { box-shadow:0 0 0 5px transparent; opacity:0.8; }
}

/* ── TOPBAR ── */
.topbar {
height:56px; flex-shrink:0;
display:flex; align-items:center; justify-content:space-between;
padding:0 16px; gap:10px;
background:rgba(6,13,26,0.85);
border-bottom:1px solid var(–rim);
backdrop-filter:blur(20px);
-webkit-backdrop-filter:blur(20px);
position:sticky; top:0; z-index:100;
}
.logo-wrap { display:flex; align-items:center; gap:10px; flex-shrink:0; min-width:0; }
.logo-mark {
width:36px; height:36px; border-radius:10px; flex-shrink:0;
background:linear-gradient(135deg, var(–amber), #d97706);
display:flex; align-items:center; justify-content:center;
font-size:18px;
box-shadow:0 4px 16px rgba(245,158,11,0.4);
}
.logo-name {
font-size:15px; font-weight:800;
background:linear-gradient(135deg, #fff 30%, var(–amber2));
-webkit-background-clip:text; -webkit-text-fill-color:transparent;
white-space:nowrap;
}
.logo-sub { font-size:10px; color:var(–muted); margin-top:-2px; }
.topbar-right { display:flex; align-items:center; gap:8px; flex-shrink:0; }

/* ── USER CHIP ── */
.user-chip {
display:flex; align-items:center; gap:8px;
background:var(–glass2); border:1px solid var(–rim);
border-radius:20px; padding:4px 12px 4px 4px;
cursor:pointer; transition:all 0.2s;
}
.user-chip:hover { border-color:var(–rim2); }
.user-av {
width:28px; height:28px; border-radius:50%;
display:flex; align-items:center; justify-content:center;
font-size:12px; font-weight:800; flex-shrink:0;
}
.user-av-admin { background:linear-gradient(135deg,var(–amber),#d97706); color:#000; }
.user-av-driver { background:linear-gradient(135deg,var(–green),#059669); color:#fff; }

/* ── NOTIFICATION CHIP ── */
.notif-chip {
background:var(–red); color:#fff;
border-radius:16px; padding:4px 10px;
font-size:11px; font-weight:700;
cursor:pointer; display:flex; align-items:center; gap:5px;
animation:notifPulse 3s infinite;
}
@keyframes notifPulse { 0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,0.4);} 50%{box-shadow:0 0 0 6px transparent;} }

/* ── TABBAR ── */
.tabbar {
display:flex; overflow-x:auto; scrollbar-width:none;
background:rgba(6,13,26,0.7);
border-bottom:1px solid var(–rim);
backdrop-filter:blur(12px);
flex-shrink:0;
}
.tabbar::-webkit-scrollbar { display:none; }
.tab {
display:flex; align-items:center; gap:6px;
padding:12px 18px; flex-shrink:0;
font-size:12px; font-weight:700; letter-spacing:0.3px;
color:var(–muted); cursor:pointer;
border-bottom:2px solid transparent;
transition:all 0.2s; white-space:nowrap;
}
.tab.active { color:var(–amber); border-color:var(–amber); }
.tab:hover:not(.active) { color:var(–text2); }

/* ── PAGE ── */
#appShell { display:none; flex-direction:column; height:100%; position:relative; z-index:1; }
#content { flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; }
#content::-webkit-scrollbar { width:3px; }
#content::-webkit-scrollbar-thumb { background:var(–rim); border-radius:2px; }
.page { padding:16px; max-width:1120px; margin:0 auto; }

/* ── STAT CARD ── */
.stat-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(130px,1fr)); gap:10px; }
.stat-box {
background:var(–glass); border:1px solid var(–rim);
border-radius:var(–r-md); padding:14px;
transition:transform 0.2s;
}
.stat-box:hover { transform:translateY(-2px); }
.stat-num { font-size:28px; font-weight:800; font-family:‘Space Mono’,monospace; margin-bottom:3px; }
.stat-lbl { font-size:11px; font-weight:600; color:var(–muted); text-transform:uppercase; letter-spacing:0.6px; }

/* ── MAP ── */
.map-wrap {
height:280px; border-radius:0 0 var(–r-lg) var(–r-lg);
overflow:hidden; position:relative;
}
#adminMap, #driverMap { width:100%; height:100%; }
.leaflet-container { background:#0d1829 !important; }
.map-legend-box {
position:absolute; bottom:10px; right:10px; z-index:1000;
background:rgba(6,13,26,0.9); border:1px solid var(–rim);
border-radius:var(–r-sm); padding:8px 11px; font-size:10px;
backdrop-filter:blur(8px);
}
.map-legend-row { display:flex; align-items:center; gap:6px; margin-bottom:3px; }
.map-legend-row:last-child { margin-bottom:0; }

/* ── VEHICLE CARD ── */
.vc-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:12px; }
.vc {
background:var(–glass); border:1px solid var(–rim);
border-radius:var(–r-lg); padding:16px;
cursor:pointer; transition:all 0.2s; position:relative;
overflow:hidden;
}
.vc::before {
content:’’; position:absolute; top:0; left:0; right:0; height:1px;
background:linear-gradient(90deg, transparent, var(–amber-glow), transparent);
opacity:0; transition:opacity 0.3s;
}
.vc:hover { border-color:var(–rim2); transform:translateY(-3px); box-shadow:var(–shadow); }
.vc:hover::before { opacity:1; }
.vc.active-vc { border-color:rgba(16,185,129,0.4); }
.vc.active-vc::before { opacity:1; background:linear-gradient(90deg, transparent, rgba(16,185,129,0.3), transparent); }

/* ── PROGRESS BAR ── */
.prog-track { height:6px; background:rgba(255,255,255,0.08); border-radius:3px; overflow:hidden; }
.prog-fill { height:100%; border-radius:3px; transition:width 0.5s; }
.prog-amber { background:linear-gradient(90deg, var(–amber), var(–amber2)); }
.prog-green { background:linear-gradient(90deg, var(–green), var(–cyan)); }

/* ── GROUP CARD ── */
.gc {
background:var(–glass); border:1px solid var(–rim);
border-radius:var(–r-lg); overflow:hidden;
transition:border-color 0.2s;
margin-bottom:12px;
}
.gc:hover { border-color:var(–rim2); }
.gc-head {
padding:13px 16px; border-bottom:1px solid var(–rim);
display:flex; align-items:center; justify-content:space-between;
}
.gc-strip {
width:4px; height:100%; position:absolute; left:0; top:0; border-radius:2px 0 0 0;
}
.gc-students { max-height:180px; overflow-y:auto; }
.gc-students::-webkit-scrollbar { width:3px; }
.gc-students::-webkit-scrollbar-thumb { background:var(–rim); }
.gc-row {
display:flex; align-items:center; gap:8px;
padding:7px 16px; font-size:12px;
border-bottom:1px solid rgba(255,255,255,0.04);
}
.gc-row:last-child { border-bottom:none; }
.gc-row:nth-child(even) { background:rgba(255,255,255,0.02); }
.gc-foot { padding:10px 16px; border-top:1px solid var(–rim); display:flex; gap:8px; }

/* ── STUDENT CARD ── */
.sc {
background:var(–glass); border:1px solid var(–rim);
border-radius:var(–r-md); overflow:hidden;
margin-bottom:10px; transition:border-color 0.2s;
}
.sc.sc-picked { border-color:rgba(16,185,129,0.35); }
.sc-head { padding:11px 14px; border-bottom:1px solid var(–rim); display:flex; align-items:center; gap:10px; }
.sc-num {
width:26px; height:26px; border-radius:7px; flex-shrink:0;
background:rgba(255,255,255,0.06); border:1px solid var(–rim);
display:flex; align-items:center; justify-content:center;
font-family:‘Space Mono’,monospace; font-size:11px; font-weight:700; color:var(–muted);
}
.sc-num.picked { background:rgba(16,185,129,0.15); color:var(–green2); border-color:rgba(16,185,129,0.3); }
.sc-body { padding:10px 14px; }
.sc-addr { font-size:12px; color:var(–text2); display:flex; gap:6px; margin-bottom:9px; }
.sc-phones { display:flex; gap:6px; }
.sc-phone {
flex:1; background:rgba(255,255,255,0.04); border:1px solid var(–rim);
border-radius:var(–r-sm); padding:7px 10px; cursor:pointer; transition:all 0.2s;
}
.sc-phone:hover { border-color:rgba(245,158,11,0.4); background:rgba(245,158,11,0.05); }
.sc-phone-lbl { font-size:9px; font-weight:700; letter-spacing:0.7px; color:var(–muted); text-transform:uppercase; }
.sc-phone-num { font-family:‘Space Mono’,monospace; font-size:11px; margin-top:2px; }

/* ── BIG ACTION BUTTONS ── */
.action-btn {
width:100%; padding:16px; border-radius:var(–r-md);
font-family:‘Plus Jakarta Sans’,sans-serif;
font-size:15px; font-weight:800;
border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:10px;
transition:all 0.2s; margin-bottom:10px;
}
.action-btn:active { transform:scale(0.98); }
.action-green {
background:linear-gradient(135deg, var(–green), #059669);
color:#fff; box-shadow:0 6px 24px rgba(16,185,129,0.35);
}
.action-green:hover { box-shadow:0 8px 32px rgba(16,185,129,0.5); }
.action-amber {
background:linear-gradient(135deg, var(–amber), #d97706);
color:#000; box-shadow:0 6px 24px rgba(245,158,11,0.35);
}
.action-outline-red {
background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.3);
color:var(–red2);
}
.action-outline-red:hover { background:rgba(239,68,68,0.14); }

/* ── DRIVER SIDEBAR ── */
.drv-layout { display:grid; grid-template-columns:260px 1fr; gap:14px; }
@media(max-width:640px) {
.drv-layout { grid-template-columns:1fr; }
.drv-sb { order:2; }
}
.drv-sb { display:flex; flex-direction:column; gap:12px; }
.group-btn {
display:flex; align-items:center; gap:10px;
padding:11px 14px; border-radius:var(–r-md);
background:var(–glass); border:1px solid var(–rim);
cursor:pointer; transition:all 0.2s; margin-bottom:7px;
}
.group-btn:hover { border-color:var(–rim2); background:var(–glass2); }
.group-btn.active-gb { border-color:rgba(16,185,129,0.4); background:rgba(16,185,129,0.06); }
.group-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

/* ── STOP COUNTDOWN ── */
.stop-cd {
background:linear-gradient(135deg, rgba(245,158,11,0.1), rgba(251,191,36,0.06));
border:1.5px solid rgba(245,158,11,0.4);
border-radius:var(–r-lg); padding:16px; margin-bottom:14px;
animation:stopBorderPulse 2s infinite;
}
@keyframes stopBorderPulse {
0%,100% { border-color:rgba(245,158,11,0.4); }
50% { border-color:rgba(245,158,11,0.15); }
}
.stop-timer-num { font-size:40px; font-weight:700; font-family:‘Space Mono’,monospace; color:var(–amber); line-height:1; }

/* ── ROUTE TIMELINE ── */
.rtl { position:relative; padding-left:28px; }
.rtl-line { position:absolute; left:10px; top:8px; bottom:8px; width:2px; background:var(–rim); }
.rti { position:relative; padding:6px 0 6px 18px; }
.rtd {
position:absolute; left:-19px; top:9px;
width:13px; height:13px; border-radius:50%;
border:2px solid; display:flex; align-items:center; justify-content:center;
font-size:6px; font-weight:700;
}
.rtd-done { background:var(–green); border-color:var(–green); color:#fff; }
.rtd-cur { background:var(–blue); border-color:var(–blue); color:#fff; animation:pulseAnim 1.5s infinite; }
.rtd-stop { background:var(–amber); border-color:var(–amber); color:#000; }
.rtd-skip { background:var(–red); border-color:var(–red); color:#fff; }
.rtd-up { background:var(–ink3); border-color:var(–rim); }
.rtc {
background:var(–glass); border:1px solid var(–rim);
border-radius:8px; padding:7px 11px;
display:flex; align-items:center; gap:9px; font-size:12px;
}
.rtc-cur { border-color:rgba(59,130,246,0.4); }
.rtc-stop { border-color:rgba(245,158,11,0.4); background:rgba(245,158,11,0.04); }
.rtc-done { opacity:0.55; }

/* ── TRAFFIC BAR ── */
.traffic-row {
display:flex; align-items:center; gap:10px;
padding:10px 14px; border-radius:var(–r-md);
margin-bottom:14px; border:1px solid;
font-size:13px; font-weight:600;
flex-wrap:wrap; gap:8px;
}
.tf-green { background:rgba(16,185,129,0.07); border-color:rgba(16,185,129,0.3); }
.tf-amber { background:rgba(245,158,11,0.07); border-color:rgba(245,158,11,0.3); }
.tf-red   { background:rgba(239,68,68,0.07); border-color:rgba(239,68,68,0.3); }
.tf-btn {
padding:4px 10px; border-radius:6px; border:1px solid var(–rim);
background:transparent; font-family:‘Plus Jakarta Sans’,sans-serif;
font-size:11px; font-weight:700; cursor:pointer; transition:all 0.2s;
}
.tf-btn.tf-sel-green { border-color:var(–green); background:rgba(16,185,129,0.15); color:var(–green2); }
.tf-btn.tf-sel-amber { border-color:var(–amber); background:rgba(245,158,11,0.15); color:var(–amber2); }
.tf-btn.tf-sel-red   { border-color:var(–red); background:rgba(239,68,68,0.15); color:var(–red2); }

/* ── MODAL ── */
.ov {
position:fixed; inset:0; z-index:400;
background:rgba(0,0,0,0.65); backdrop-filter:blur(8px);
display:flex; align-items:center; justify-content:center; padding:16px;
opacity:0; pointer-events:none; transition:opacity 0.25s;
}
.ov.open { opacity:1; pointer-events:all; }
.modal {
background:var(–ink2); border:1px solid var(–rim2);
border-radius:var(–r-xl); width:100%; max-width:500px;
max-height:92vh; overflow-y:auto;
box-shadow:0 32px 64px rgba(0,0,0,0.6);
transform:scale(0.95) translateY(8px);
transition:transform 0.25s cubic-bezier(0.34,1.56,0.64,1);
}
.ov.open .modal { transform:scale(1) translateY(0); }
.modal::-webkit-scrollbar { width:3px; }
.modal::-webkit-scrollbar-thumb { background:var(–rim); }
.mh {
padding:20px 22px 0;
display:flex; align-items:center; justify-content:space-between;
margin-bottom:2px;
}
.mt { font-size:17px; font-weight:800; }
.mc {
width:30px; height:30px; border-radius:8px;
background:var(–glass2); border:1px solid var(–rim);
cursor:pointer; color:var(–text); font-size:13px;
display:flex; align-items:center; justify-content:center;
transition:all 0.2s;
}
.mc:hover { border-color:rgba(239,68,68,0.5); color:var(–red2); }
.mb { padding:16px 22px 22px; }

/* ── LICENSE SCREEN ── */
#licScreen {
position:fixed; inset:0; z-index:1000;
display:none; align-items:center; justify-content:center; padding:20px;
background:var(–ink);
}
#licScreen::before {
content:’’; position:absolute; inset:0;
background:
radial-gradient(ellipse 70% 50% at 30% 0%, rgba(245,158,11,0.12) 0%, transparent 55%),
radial-gradient(ellipse 60% 40% at 70% 100%, rgba(59,130,246,0.08) 0%, transparent 55%);
pointer-events:none;
}
#licScreen.show { display:flex; }
.lic-card {
background:rgba(13,24,41,0.9); border:1px solid var(–rim2);
border-radius:var(–r-xl); width:100%; max-width:430px;
padding:32px; box-shadow:0 40px 80px rgba(0,0,0,0.7);
position:relative; z-index:1;
backdrop-filter:blur(20px);
}
.lic-logo { text-align:center; margin-bottom:28px; }
.lic-icon {
width:72px; height:72px; border-radius:20px; margin:0 auto 14px;
background:linear-gradient(135deg, var(–amber), #d97706);
display:flex; align-items:center; justify-content:center;
font-size:36px; box-shadow:0 8px 32px rgba(245,158,11,0.45);
}
.lic-title-txt {
font-size:26px; font-weight:800;
background:linear-gradient(135deg, #fff 20%, var(–amber2));
-webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
.lic-sub-txt { font-size:13px; color:var(–muted); margin-top:6px; line-height:1.6; }

.code-input {
width:100%;
background:rgba(255,255,255,0.04);
border:1.5px solid var(–rim2);
border-radius:var(–r-md);
padding:16px; text-align:center;
font-family:‘Space Mono’,monospace;
font-size:20px; font-weight:700;
letter-spacing:4px; text-transform:uppercase;
color:var(–text); outline:none;
transition:all 0.2s;
margin:16px 0 8px;
}
.code-input:focus { border-color:rgba(245,158,11,0.6); background:rgba(245,158,11,0.04); }
.code-input.ok  { border-color:rgba(16,185,129,0.6); background:rgba(16,185,129,0.05); color:var(–green2); }
.code-input.bad { border-color:rgba(239,68,68,0.6); background:rgba(239,68,68,0.04); }

.lic-msg {
text-align:center; padding:9px 14px; border-radius:var(–r-sm);
font-size:13px; font-weight:600; display:none; margin-bottom:12px;
}
.lic-msg.show { display:block; }
.lic-msg.ok { background:rgba(16,185,129,0.12); color:var(–green2); border:1px solid rgba(16,185,129,0.3); }
.lic-msg.err { background:rgba(239,68,68,0.1); color:var(–red2); border:1px solid rgba(239,68,68,0.3); }

/* Dev Panel */
.dev-table { display:flex; flex-direction:column; gap:8px; max-height:300px; overflow-y:auto; }
.dev-row {
display:flex; align-items:center; gap:10px;
padding:10px 13px; border-radius:var(–r-md);
background:rgba(255,255,255,0.04); border:1px solid var(–rim);
}
.dev-row.dr-active { border-color:rgba(16,185,129,0.3); background:rgba(16,185,129,0.05); }
.dev-row.dr-pending { border-color:rgba(245,158,11,0.3); background:rgba(245,158,11,0.04); }
.dev-row.dr-expired { opacity:0.55; }
.dev-code { font-family:‘Space Mono’,monospace; font-size:13px; font-weight:700; letter-spacing:1px; }

/* ── TOAST ── */
#tc { position:fixed; bottom:18px; right:18px; z-index:800; display:flex; flex-direction:column; gap:8px; pointer-events:none; }
.toast {
display:flex; align-items:center; gap:9px;
padding:11px 15px; border-radius:var(–r-md);
background:rgba(13,24,41,0.95); border:1px solid var(–rim2);
font-size:13px; font-weight:600; min-width:210px; max-width:300px;
box-shadow:0 10px 32px rgba(0,0,0,0.5);
backdrop-filter:blur(12px);
animation:toastIn 0.3s cubic-bezier(0.34,1.56,0.64,1);
pointer-events:all;
}
.toast.success { border-color:rgba(16,185,129,0.5); }
.toast.error   { border-color:rgba(239,68,68,0.5); }
.toast.warning { border-color:rgba(245,158,11,0.5); }
.toast.info    { border-color:rgba(59,130,246,0.5); }
@keyframes toastIn { from { transform:translateX(110%); opacity:0; } to { transform:translateX(0); opacity:1; } }

/* ── SEPARATOR ── */
.sep { height:1px; background:var(–rim); margin:14px 0; }
.sep-row { display:flex; align-items:center; gap:12px; margin:16px 0; }
.sep-row::before,.sep-row::after { content:’’; flex:1; height:1px; background:var(–rim); }

/* ── PROJECT SCREEN ── */
#projScreen {
position:fixed; inset:0; z-index:200;
display:none; align-items:flex-start; justify-content:center;
padding:24px 16px; overflow-y:auto;
background:var(–ink);
}
#projScreen::before {
content:’’; position:fixed; inset:0;
background:
radial-gradient(ellipse 80% 50% at 15% -5%, rgba(245,158,11,0.07) 0%, transparent 55%),
radial-gradient(ellipse 60% 40% at 85% 105%, rgba(59,130,246,0.06) 0%, transparent 55%);
pointer-events:none; z-index:0;
}
#projScreen.show { display:flex; }
.proj-inner { width:100%; max-width:760px; position:relative; z-index:1; }
.proj-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(210px,1fr)); gap:12px; margin-bottom:14px; }
.proj-card {
background:var(–glass); border:1.5px solid var(–rim);
border-radius:var(–r-xl); padding:20px;
cursor:pointer; transition:all 0.25s; position:relative; overflow:hidden;
}
.proj-card::after {
content:’’; position:absolute; inset:0; border-radius:var(–r-xl);
background:linear-gradient(135deg, rgba(255,255,255,0.05), transparent);
opacity:0; transition:opacity 0.25s;
}
.proj-card:hover { border-color:rgba(245,158,11,0.4); transform:translateY(-4px); box-shadow:0 16px 40px rgba(0,0,0,0.5); }
.proj-card:hover::after { opacity:1; }
.proj-icon { width:48px; height:48px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:24px; margin-bottom:12px; }
.proj-add-card {
background:transparent; border:1.5px dashed var(–rim);
display:flex; flex-direction:column; align-items:center; justify-content:center;
min-height:130px;
}
.proj-add-card:hover { border-color:rgba(245,158,11,0.4); background:rgba(245,158,11,0.03); }
.pend-notif {
display:flex; align-items:center; gap:12px;
padding:13px 16px; border-radius:var(–r-md);
background:rgba(245,158,11,0.08); border:1px solid rgba(245,158,11,0.3);
cursor:pointer; transition:all 0.2s; margin-bottom:14px;
}
.pend-notif:hover { background:rgba(245,158,11,0.13); }

/* QR */
.qr-box { background:#fff; border-radius:var(–r-md); padding:14px; display:inline-block; }

/* Help */
.help-slide {
position:fixed; right:0; top:56px; bottom:0; width:310px; z-index:300;
background:rgba(6,13,26,0.97); border-left:1px solid var(–rim);
backdrop-filter:blur(20px); display:flex; flex-direction:column;
transform:translateX(100%); transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);
}
.help-slide.open { transform:translateX(0); }
.help-hd { padding:14px 16px; border-bottom:1px solid var(–rim); display:flex; align-items:center; justify-content:space-between; }
.help-body { flex:1; overflow-y:auto; padding:14px 16px; }
.help-body::-webkit-scrollbar { width:3px; }
.help-body::-webkit-scrollbar-thumb { background:var(–rim); }
.help-item { background:var(–glass); border-radius:var(–r-md); padding:13px; margin-bottom:10px; border:1px solid var(–rim); }
.help-item-title { font-size:13px; font-weight:700; margin-bottom:5px; display:flex; align-items:center; gap:8px; }
.help-item-text { font-size:12px; color:var(–text2); line-height:1.7; }

/* VOICE BTN */
.voice-btn {
width:36px; height:36px; border-radius:50%;
background:var(–glass2); border:1.5px solid var(–rim);
cursor:pointer; display:flex; align-items:center; justify-content:center;
font-size:16px; transition:all 0.2s; flex-shrink:0;
}
.voice-btn.speaking { border-color:rgba(16,185,129,0.6); background:rgba(16,185,129,0.12); animation:pulseAnim 1.5s infinite; }

/* ASSIGN MODAL */
.assign-drv-row {
display:flex; align-items:center; gap:11px;
padding:11px 13px; border-radius:var(–r-md);
background:var(–glass); border:1.5px solid var(–rim);
cursor:pointer; transition:all 0.2s; margin-bottom:8px;
}
.assign-drv-row:hover { border-color:var(–rim2); }
.assign-drv-row.sel { border-color:rgba(245,158,11,0.5); background:rgba(245,158,11,0.06); }

/* Summary rows */
.sum-row { display:flex; justify-content:space-between; align-items:flex-start; padding:7px 0; border-bottom:1px solid var(–rim); font-size:13px; }
.sum-row:last-child { border-bottom:none; }
.sum-lbl { color:var(–muted); font-size:12px; }
.sum-val { font-weight:600; text-align:right; max-width:60%; }

/* BASVURU */
.bas-card { background:var(–glass); border:1px solid var(–rim); border-radius:var(–r-lg); margin-bottom:10px; overflow:hidden; transition:border-color 0.2s; }
.bas-card:hover { border-color:var(–rim2); }
.bas-head { padding:11px 15px; border-bottom:1px solid var(–rim); display:flex; align-items:center; gap:9px; }
.bas-body { padding:11px 15px; display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.bas-f { padding:10px 15px; border-top:1px solid var(–rim); display:flex; gap:7px; flex-wrap:wrap; }
.bas-info-lbl { font-size:10px; font-weight:700; color:var(–muted); text-transform:uppercase; letter-spacing:0.6px; }
.bas-info-val { font-size:12px; font-weight:600; margin-top:2px; }

/* GPS badge */
.gps-pill {
display:inline-flex; align-items:center; gap:5px;
padding:4px 9px; border-radius:14px; font-size:10px; font-weight:700;
}
.gps-ok  { background:rgba(16,185,129,0.15); color:var(–green2); border:1px solid rgba(16,185,129,0.3); }
.gps-wait { background:rgba(245,158,11,0.12); color:var(–amber2); border:1px solid rgba(245,158,11,0.3); }

/* Driver map mini */
.drv-map-mini { height:180px; border-radius:var(–r-md); overflow:hidden; border:1px solid var(–rim); margin-bottom:10px; }

/* Veli form steps */
.vsteps { display:flex; align-items:center; justify-content:center; margin-bottom:22px; }
.vstep { display:flex; flex-direction:column; align-items:center; gap:4px; flex:1; }
.vstep-c { width:30px; height:30px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; border:2px solid var(–rim); background:var(–ink3); color:var(–muted); transition:all 0.3s; }
.vstep.v-done .vstep-c { background:var(–green); border-color:var(–green); color:#fff; }
.vstep.v-act .vstep-c  { background:var(–amber); border-color:var(–amber); color:#000; }
.vstep-l { font-size:10px; color:var(–muted); white-space:nowrap; }
.vstep.v-act .vstep-l  { color:var(–amber2); }
.vstep.v-done .vstep-l { color:var(–green2); }
.vstep-line { flex:1; height:2px; background:var(–rim); align-self:flex-start; margin-top:13px; max-width:36px; }
.vstep-line.v-done { background:var(–green); }

/* Color swatch */
.swatch { width:28px; height:28px; border-radius:50%; cursor:pointer; border:3px solid transparent; transition:transform 0.15s; }
.swatch:hover { transform:scale(1.15); }
.swatch.sel { border-color:#fff; }

/* Section header */
.sh { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; flex-wrap:wrap; gap:8px; }
.divider { height:1px; background:var(–rim); margin:16px 0; }

/* GPS Coords */
#gpsCoordsTxt { font-family:‘Space Mono’,monospace; font-size:10px; color:var(–muted); }

/* ── ROUTE OPTIMIZATION ── */
#routeMap { width:100%; height:100%; }
.route-map-wrap {
height:420px; border-radius:var(–r-lg); overflow:hidden;
border:1px solid var(–rim); position:relative;
margin-bottom:14px;
}
.route-map-controls {
position:absolute; top:10px; left:10px; z-index:1000;
display:flex; flex-direction:column; gap:6px;
}
.rmc-btn {
background:rgba(6,13,26,0.92); border:1px solid var(–rim2);
border-radius:var(–r-sm); padding:7px 12px;
font-family:‘Plus Jakarta Sans’,sans-serif; font-size:12px; font-weight:700;
color:var(–text); cursor:pointer; backdrop-filter:blur(8px);
display:flex; align-items:center; gap:7px; white-space:nowrap;
transition:all 0.2s;
}
.rmc-btn:hover { border-color:var(–amber); color:var(–amber2); }
.rmc-btn.active { border-color:var(–amber); background:rgba(245,158,11,0.12); color:var(–amber2); }
.route-legend {
position:absolute; bottom:10px; right:10px; z-index:1000;
background:rgba(6,13,26,0.92); border:1px solid var(–rim2);
border-radius:var(–r-md); padding:10px 13px;
backdrop-filter:blur(8px); font-size:11px; min-width:160px;
}
.route-legend-title { font-weight:700; margin-bottom:8px; color:var(–muted); letter-spacing:0.5px; text-transform:uppercase; font-size:10px; }
.rl-row { display:flex; align-items:center; gap:8px; margin-bottom:5px; }
.rl-row:last-child { margin-bottom:0; }
.rl-line { width:28px; height:3px; border-radius:2px; flex-shrink:0; }
.rl-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

/* Overlap panel */
.overlap-panel {
background:rgba(239,68,68,0.07); border:1px solid rgba(239,68,68,0.3);
border-radius:var(–r-lg); padding:16px; margin-bottom:14px;
}
.overlap-item {
background:rgba(255,255,255,0.04); border:1px solid rgba(239,68,68,0.2);
border-radius:var(–r-md); padding:12px 14px; margin-bottom:10px;
transition:border-color 0.2s;
}
.overlap-item:hover { border-color:rgba(239,68,68,0.4); }
.overlap-item:last-child { margin-bottom:0; }

/* Transfer suggestion */
.transfer-card {
background:rgba(16,185,129,0.07); border:1px solid rgba(16,185,129,0.3);
border-radius:var(–r-md); padding:12px 14px; margin-bottom:10px;
transition:border-color 0.2s;
}
.transfer-card:hover { border-color:rgba(16,185,129,0.5); }

/* Group selector chips */
.group-chip-row { display:flex; gap:7px; flex-wrap:wrap; margin-bottom:12px; }
.group-chip {
display:flex; align-items:center; gap:6px;
padding:6px 12px; border-radius:20px;
border:1.5px solid; cursor:pointer; font-size:12px; font-weight:700;
transition:all 0.2s; background:transparent;
font-family:‘Plus Jakarta Sans’,sans-serif;
}
.group-chip:hover { opacity:0.85; }
.group-chip.chip-off { opacity:0.35; }

/* Km savings banner */
.km-savings {
background:linear-gradient(135deg, rgba(16,185,129,0.1), rgba(6,182,212,0.06));
border:1px solid rgba(16,185,129,0.3); border-radius:var(–r-lg);
padding:16px; display:flex; align-items:center; gap:14px; margin-bottom:14px;
}
.km-savings-num { font-family:‘Space Mono’,monospace; font-size:32px; font-weight:700; color:var(–green2); }

/* Student transfer drag row */
.stud-transfer-row {
display:flex; align-items:center; gap:8px;
padding:9px 12px; border-radius:var(–r-md);
background:var(–glass); border:1px solid var(–rim);
margin-bottom:7px; font-size:12px; cursor:grab;
transition:all 0.2s;
}
.stud-transfer-row:hover { border-color:var(–rim2); background:var(–glass2); }
.stud-transfer-row.dragging { opacity:0.5; border-color:var(–amber); cursor:grabbing; }

/* Drop zone */
.drop-zone {
border:2px dashed var(–rim); border-radius:var(–r-md);
padding:14px; text-align:center; color:var(–muted);
font-size:12px; transition:all 0.2s; min-height:60px;
display:flex; align-items:center; justify-content:center;
}
.drop-zone.drag-over { border-color:var(–amber); background:rgba(245,158,11,0.06); color:var(–amber2); }

/* Route stats grid */
.route-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(110px,1fr)); gap:8px; margin-bottom:14px; }
.route-stat { background:var(–glass); border:1px solid var(–rim); border-radius:var(–r-md); padding:11px; text-align:center; }
.route-stat-num { font-family:‘Space Mono’,monospace; font-size:20px; font-weight:700; }
.route-stat-lbl { font-size:10px; color:var(–muted); text-transform:uppercase; letter-spacing:0.5px; margin-top:3px; }
</style>

</head>
<body>

<!-- ───── LICENSE SCREEN ───── -->

<div id="licScreen">
  <div class="lic-card" id="licCard"></div>
</div>

<!-- ───── PROJECT SCREEN ───── -->

<div id="projScreen">
  <div class="proj-inner">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px">
      <div style="display:flex;align-items:center;gap:12px">
        <div style="width:44px;height:44px;border-radius:13px;background:linear-gradient(135deg,var(--amber),#d97706);display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:0 6px 20px rgba(245,158,11,0.4)">🚌</div>
        <div>
          <div style="font-size:20px;font-weight:800">Servis Asistanı</div>
          <div style="font-size:12px;color:var(--muted)" id="projWelcome">Hoş geldiniz</div>
        </div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost btn-sm" onclick="openHelpPanel('proj')">❓ Yardım</button>
        <button class="btn btn-ghost btn-sm" onclick="switchAccount()">👤 Hesap</button>
      </div>
    </div>
    <div class="label" style="margin-bottom:10px">Projelerim — Okul / İşletme</div>
    <div class="proj-grid" id="projGrid"></div>
    <div class="card" style="padding:16px;margin-top:8px">
      <div style="font-size:13px;font-weight:700;margin-bottom:7px">💡 Nasıl Çalışır?</div>
      <div style="font-size:12px;color:var(--text2);line-height:1.8">
        Her proje = bir okul veya işletme. Farklı adminler aynı uygulamayı kendi projelerinde bağımsız kullanır.<br>
        Bir admin en fazla <strong>5 proje</strong> yönetebilir.
      </div>
    </div>
  </div>
</div>

<!-- ───── APP SHELL ───── -->

<div id="appShell">
  <div class="topbar">
    <div class="logo-wrap">
      <div class="logo-mark">🚌</div>
      <div>
        <div class="logo-name" id="projTitleTxt">Servis Asistanı</div>
        <div class="logo-sub" id="projSubTxt"></div>
      </div>
    </div>
    <div class="topbar-right">
      <div class="notif-chip" id="pendBadge" style="display:none" onclick="switchTab('admin_bas')">
        🔔 <span id="pendCount">0</span>
      </div>
      <button class="voice-btn" id="voiceBtn" onclick="toggleVoice()" title="Sesli rehber">🔇</button>
      <button class="btn btn-ghost btn-sm" onclick="openHelpPanel(currentTab)" style="padding:6px 10px">❓</button>
      <div class="user-chip" onclick="goProjects()">
        <div class="user-av" id="uAv"></div>
        <div style="font-size:11px;font-weight:700;max-width:70px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" id="uNm"></div>
      </div>
    </div>
  </div>
  <div class="tabbar" id="tabBar"></div>
  <div id="content" class="scr"></div>
</div>

<!-- ───── HELP PANEL ───── -->

<div class="help-slide" id="helpSlide">
  <div class="help-hd">
    <div style="font-size:14px;font-weight:700">❓ Yardım & Rehber</div>
    <div style="display:flex;gap:8px">
      <button class="voice-btn" id="helpVoiceBtn" onclick="speakCurrentHelp()">🔊</button>
      <button class="mc" onclick="closeHelp()">✕</button>
    </div>
  </div>
  <div class="help-body" id="helpBody"></div>
</div>

