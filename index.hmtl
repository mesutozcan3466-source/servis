<!-- Login -->

<div class="ov" id="loginModal">
  <div class="modal" style="max-width:440px">
    <div class="mh"><div class="mt">Giriş Yap / Kayıt Ol</div></div>
    <div class="mb">
      <div class="fg">
        <div class="label" style="margin-bottom:8px">Rolünüzü Seçin</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:9px">
          <div id="roleAdmCard" onclick="selRole('admin')" style="padding:13px;border-radius:var(--r-md);border:2px solid var(--amber);background:rgba(245,158,11,0.08);cursor:pointer;text-align:center;transition:all 0.2s">
            <div style="font-size:24px;margin-bottom:5px">🖥️</div>
            <div style="font-size:13px;font-weight:700">Admin</div>
            <div style="font-size:10px;color:var(--muted);margin-top:2px">Yönetici</div>
          </div>
          <div id="roleDrvCard" onclick="selRole('driver')" style="padding:13px;border-radius:var(--r-md);border:2px solid var(--rim);background:var(--glass);cursor:pointer;text-align:center;transition:all 0.2s">
            <div style="font-size:24px;margin-bottom:5px">🚌</div>
            <div style="font-size:13px;font-weight:700">Şoför</div>
            <div style="font-size:10px;color:var(--muted);margin-top:2px">Sürücü</div>
          </div>
        </div>
      </div>
      <div class="fg-row">
        <div class="fg"><label class="fl">Ad Soyad <span class="req">*</span></label><input class="fi" id="l_name" placeholder="Ahmet Yılmaz"></div>
        <div class="fg"><label class="fl">Sıfat</label><input class="fi" id="l_title" placeholder="Koordinatör..."></div>
      </div>
      <div id="drvFields">
        <div class="fg-row">
          <div class="fg"><label class="fl">Plaka</label><input class="fi" id="l_plate" placeholder="34 ABC 123" style="text-transform:uppercase"></div>
          <div class="fg"><label class="fl">Araç No</label><input class="fi" id="l_vno" placeholder="Servis-1"></div>
        </div>
        <div class="fg"><label class="fl">Telefon</label><input class="fi" id="l_phone" placeholder="05XX XXX XX XX" type="tel"></div>
      </div>
      <button class="btn btn-amber btn-block btn-lg" onclick="doLogin()" style="margin-top:8px">Giriş Yap →</button>
      <div style="text-align:center;margin-top:12px;font-size:12px;color:var(--muted)">
        Hızlı test: <button onclick="loadDemo()" style="background:none;border:none;color:var(--amber2);font-size:12px;cursor:pointer;font-family:inherit;font-weight:700">Demo Yükle</button>
      </div>
    </div>
  </div>
</div>

<!-- New Project -->

<div class="ov" id="newProjModal">
  <div class="modal" style="max-width:440px">
    <div class="mh"><div class="mt">➕ Yeni Proje</div><button class="mc" onclick="closeModal('newProjModal')">✕</button></div>
    <div class="mb">
      <div class="fg"><label class="fl">Proje Adı <span class="req">*</span></label><input class="fi" id="pj_name" placeholder="Atatürk İlkokulu Servisi"></div>
      <div class="fg-row">
        <div class="fg"><label class="fl">Şehir</label><input class="fi" id="pj_city" placeholder="İstanbul"></div>
        <div class="fg"><label class="fl">İkon</label><input class="fi" id="pj_icon" placeholder="🏫" maxlength="2" value="🏫"></div>
      </div>
      <div class="fg">
        <label class="fl">Renk</label>
        <div style="display:flex;gap:9px;margin-top:5px" id="swatches">
          <div class="swatch sel" style="background:#f59e0b" onclick="pickColor('#f59e0b',this)"></div>
          <div class="swatch" style="background:#3b82f6" onclick="pickColor('#3b82f6',this)"></div>
          <div class="swatch" style="background:#10b981" onclick="pickColor('#10b981',this)"></div>
          <div class="swatch" style="background:#8b5cf6" onclick="pickColor('#8b5cf6',this)"></div>
          <div class="swatch" style="background:#ef4444" onclick="pickColor('#ef4444',this)"></div>
          <div class="swatch" style="background:#f97316" onclick="pickColor('#f97316',this)"></div>
        </div>
      </div>
      <div style="display:flex;gap:8px;margin-top:6px">
        <button class="btn btn-ghost" style="flex:1;justify-content:center" onclick="closeModal('newProjModal')">İptal</button>
        <button class="btn btn-amber" style="flex:1;justify-content:center" onclick="createProject()">Oluştur ✓</button>
      </div>
    </div>
